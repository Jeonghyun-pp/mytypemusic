{
  "templateId": "cover.hero.v1",
  "family": "cover",
  "safeArea": {
    "top": 75,
    "right": 75,
    "bottom": 100,
    "left": 75
  },
  "slots": [
    {
      "id": "heroImage",
      "type": "image",
      "x": 0,
      "y": 0,
      "width": 1080,
      "height": 1350,
      "fit": "cover"
    },
    {
      "id": "title",
      "type": "text",
      "x": 75,
      "y": 400,
      "width": 930,
      "height": 300,
      "style": {
        "fontSize": 64,
        "fontWeight": "bold",
        "color": "#FFFFFF",
        "textShadow": "0 2px 8px rgba(0,0,0,0.6)"
      },
      "constraints": { "maxLines": 3, "maxChars": 50 }
    },
    {
      "id": "footerCredits",
      "type": "text",
      "x": 75,
      "y": 1250,
      "width": 930,
      "height": 40,
      "style": {
        "fontSize": 14,
        "color": "rgba(255,255,255,0.7)"
      },
      "constraints": { "maxLines": 1, "maxChars": 90 },
      "attributionRequired": true
    }
  ]
}
